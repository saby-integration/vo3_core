
Процедура ПослеОбновления(ПараметрыИнициализации)
	//Заполним справочник состояний объектов
	Справочники.Saby_СостоянияОбъектов.НачальнаяИнициализация();
	//Создадим ДопСведение - "КЭДО"
	СоздатьДополнительноеСвойствоКЭДО();
	ПараметрыИнициализации.ОбщиеНастройки.Вставить("ВерсияРасширения", ПараметрыИнициализации.СтатусВерсии.НомерТекущейВерсии);
	Saby_Core.ОбщиеНастройкиЗаписать(ПараметрыИнициализации.ОбщиеНастройки);
КонецПроцедуры

